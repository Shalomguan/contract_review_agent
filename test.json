              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "reviews"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
